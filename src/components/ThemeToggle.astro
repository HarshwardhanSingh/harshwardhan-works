---
// Light/dark toggle. Initial theme is set in BaseHead before paint;
// this just flips it and persists the choice to localStorage.
---

<button id="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle theme">
	<svg class="sun" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
		<circle cx="12" cy="12" r="4" fill="currentColor"></circle>
		<g stroke="currentColor" stroke-width="2" stroke-linecap="round">
			<line x1="12" y1="2" x2="12" y2="4"></line>
			<line x1="12" y1="20" x2="12" y2="22"></line>
			<line x1="2" y1="12" x2="4" y2="12"></line>
			<line x1="20" y1="12" x2="22" y2="12"></line>
			<line x1="4.9" y1="4.9" x2="6.3" y2="6.3"></line>
			<line x1="17.7" y1="17.7" x2="19.1" y2="19.1"></line>
			<line x1="4.9" y1="19.1" x2="6.3" y2="17.7"></line>
			<line x1="17.7" y1="6.3" x2="19.1" y2="4.9"></line>
		</g>
	</svg>
	<svg class="moon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
		<path
			fill="currentColor"
			d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
		></path>
	</svg>
</button>

<script is:inline>
	const btn = document.getElementById("theme-toggle");
	btn?.addEventListener("click", () => {
		const next =
			document.documentElement.dataset.theme === "dark" ? "light" : "dark";
		document.documentElement.dataset.theme = next;
		localStorage.setItem("theme", next);
	});
</script>

<style>
	button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.1rem;
		height: 2.1rem;
		padding: 0;
		border: 1px solid var(--border);
		border-radius: 6px;
		background: transparent;
		color: var(--text-muted);
		cursor: pointer;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	button:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	/* Show sun in dark mode (to switch TO light), moon in light mode. */
	.sun {
		display: none;
	}
	:global(:root[data-theme="dark"]) .sun {
		display: block;
	}
	:global(:root[data-theme="dark"]) .moon {
		display: none;
	}
</style>
