---
// In-page table of contents for the left rail. Lists the current post's section
// headings (h2/h3) as jump-links, and highlights the section currently in view.
// Astro auto-assigns ids to headings, and `slug` here matches those ids.
interface Heading {
	depth: number;
	slug: string;
	text: string;
}
interface Props {
	headings: Heading[];
}
const { headings } = Astro.props;
const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
	toc.length > 0 && (
		<nav class="toc" aria-label="On this page">
			<span class="toc__kicker mono">On this page</span>
			<ul class="toc__list">
				{toc.map((h) => (
					<li class:list={["toc__item", `toc__item--h${h.depth}`]}>
						<a class="toc__link" href={`#${h.slug}`} data-toc-link={h.slug}>
							{h.text}
						</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<script>
	// Scroll spy: mark the TOC link whose section is currently in view.
	const links = new Map<string, Element>();
	document.querySelectorAll("[data-toc-link]").forEach((a) => {
		const id = a.getAttribute("data-toc-link");
		if (id) links.set(id, a);
	});

	if (links.size > 0) {
		const targets = [...links.keys()]
			.map((id) => document.getElementById(id))
			.filter((el): el is HTMLElement => el !== null);

		let active: string | null = null;
		const setActive = (id: string) => {
			if (id === active) return;
			links.forEach((a, key) => a.classList.toggle("is-active", key === id));
			active = id;
		};

		const observer = new IntersectionObserver(
			(entries) => {
				const visible = entries
					.filter((e) => e.isIntersecting)
					.sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
				if (visible[0]) setActive(visible[0].target.id);
			},
			// A band near the top: a heading is "active" once it passes the top
			// area and until the next one does.
			{ rootMargin: "-80px 0px -70% 0px", threshold: 0 },
		);
		targets.forEach((t) => observer.observe(t));
	}
</script>

<style>
	.toc__kicker {
		display: block;
		font-size: 0.66rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 0.55rem;
	}
	.toc__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.05rem;
	}
	.toc__item--h3 {
		margin-left: 0.85rem;
	}
	.toc__link {
		display: block;
		padding: 0.3rem 0.6rem;
		border-left: 2px solid transparent;
		border-radius: 0 6px 6px 0;
		font-size: 0.8rem;
		line-height: 1.35;
		color: var(--text-muted);
		text-decoration: none;
		transition:
			color 0.15s ease,
			background 0.15s ease,
			border-color 0.15s ease;
	}
	.toc__item--h3 .toc__link {
		font-size: 0.76rem;
	}
	.toc__link:hover {
		color: var(--accent);
		background: var(--bg-subtle);
		text-decoration: none;
	}
	.toc__link.is-active {
		color: var(--text);
		font-weight: 600;
		border-left-color: var(--accent);
		background: var(--bg-subtle);
	}
</style>
