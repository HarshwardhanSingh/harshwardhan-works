---
import Socials from "./Socials.astro";
import { AUTHOR } from "../consts";
const year = new Date().getFullYear();
---

<footer>
	<div class="inner">
		<span class="muted mono">© {year} {AUTHOR}</span>
		<div class="right">
			<a href="/rss.xml" class="muted" title="RSS feed">RSS</a>
			<Socials />
		</div>
	</div>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		flex-shrink: 0;
	}
	.inner {
		width: var(--maxw-wide);
		max-width: calc(100% - 2.5rem);
		margin-inline: auto;
		padding: 1.5rem 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		font-size: 0.85rem;
	}
	.right {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	.right a:hover {
		color: var(--accent);
	}
	@media (max-width: 480px) {
		.inner {
			flex-direction: column;
			gap: 0.85rem;
			text-align: center;
		}
	}
</style>
