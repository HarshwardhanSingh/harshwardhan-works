---
import FormattedDate from "./FormattedDate.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
	posts: CollectionEntry<"blog">[];
}
const { posts } = Astro.props;
---

<ul class="posts">
	{
		posts.map((post) => (
			<li>
				<a href={`/blog/${post.id}/`}>
					<span class="date mono">
						<FormattedDate date={post.data.pubDate} />
					</span>
					<span class="body">
						<span class="title">{post.data.title}</span>
						<span class="desc">{post.data.description}</span>
					</span>
				</a>
			</li>
		))
	}
</ul>

<style>
	.posts {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.posts li {
		margin: 0;
		border-top: 1px solid var(--border);
	}
	.posts li:last-child {
		border-bottom: 1px solid var(--border);
	}
	.posts a {
		display: flex;
		gap: 1.25rem;
		padding: 1.1rem 0.25rem;
		color: var(--text);
	}
	.posts a:hover {
		text-decoration: none;
	}
	.date {
		flex: 0 0 5.5rem;
		font-size: 0.78rem;
		color: var(--text-muted);
		padding-top: 0.2rem;
		white-space: nowrap;
	}
	.body {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	.title {
		font-weight: 550;
		letter-spacing: -0.01em;
		transition: color 0.15s ease;
	}
	.posts a:hover .title {
		color: var(--accent);
	}
	.desc {
		color: var(--text-muted);
		font-size: 0.92rem;
		line-height: 1.5;
	}
	@media (max-width: 540px) {
		.posts a {
			flex-direction: column;
			gap: 0.3rem;
		}
		.date {
			flex-basis: auto;
			padding-top: 0;
		}
	}
</style>
