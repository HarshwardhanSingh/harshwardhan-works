---
// Read-aloud widget for blog posts.
//
// One consistent, themed control drives both playback modes:
//   1. If a pre-generated MP3 exists at `audioSrc` (probed with a HEAD request),
//      the control plays that audio (the "podcast" narration). A slim progress
//      bar appears. Drop a file at public/audio/<slug>.mp3 and this lights up.
//   2. Otherwise it falls back to the browser's built-in speech synthesis,
//      reading the rendered article text (code, tables, and nav/checkpoint
//      callouts stripped).
//
// The <audio> element is headless (no native controls) so the UI stays the
// same in either mode. If neither mode is available, the widget hides itself.
interface Props {
	audioSrc?: string;
}
const { audioSrc } = Astro.props;
---

<div class="listen" data-listen-widget data-audio-src={audioSrc ?? ""}>
	<div class="listen-row">
		<button
			type="button"
			class="listen-btn"
			data-toggle
			aria-label="Listen to this post"
			aria-pressed="false"
		>
			<span class="ico" data-ico aria-hidden="true">▶</span>
			<span data-label>Listen</span>
		</button>
		<button type="button" class="listen-speed" data-speed aria-label="Playback speed"
			>1×</button
		>
		<span class="listen-note mono" data-note>read aloud in your browser</span>
	</div>
	<div class="listen-progress" data-progress hidden>
		<div class="listen-progress-fill" data-fill></div>
	</div>
	<audio class="listen-audio" data-audio preload="none" hidden></audio>
</div>

<script>
	type Mode = "idle" | "playing" | "paused";
	const SPEEDS = [1, 1.25, 1.5, 0.75];

	function initListenWidget() {
		const el = document.querySelector<HTMLElement>("[data-listen-widget]");
		if (!el) return;

		const audioEl = el.querySelector<HTMLAudioElement>("[data-audio]")!;
		const toggleBtn = el.querySelector<HTMLButtonElement>("[data-toggle]")!;
		const speedBtn = el.querySelector<HTMLButtonElement>("[data-speed]")!;
		const labelEl = el.querySelector<HTMLElement>("[data-label]")!;
		const icoEl = el.querySelector<HTMLElement>("[data-ico]")!;
		const noteEl = el.querySelector<HTMLElement>("[data-note]")!;
		const progressEl = el.querySelector<HTMLElement>("[data-progress]")!;
		const fillEl = el.querySelector<HTMLElement>("[data-fill]")!;

		let speedIdx = 0;
		const setSpeedLabel = () => (speedBtn.textContent = `${SPEEDS[speedIdx]}×`);

		// --- Prefer a pre-generated MP3 if one is present. -----------------------
		const src = el.dataset.audioSrc;
		if (src) {
			fetch(src, { method: "HEAD" })
				.then((r) => r.ok && setupAudioMode(src))
				.catch(() => {
					/* no MP3 — speech mode stays */
				});
		}

		// ========================================================================
		// Mode A: pre-generated narration audio.
		// ========================================================================
		function setupAudioMode(url: string) {
			audioEl.src = url;
			noteEl.hidden = true;
			progressEl.hidden = false;

			const sync = () => {
				const playing = !audioEl.paused && !audioEl.ended;
				icoEl.textContent = playing ? "⏸" : "▶";
				labelEl.textContent = playing
					? "Pause"
					: audioEl.currentTime > 0 && !audioEl.ended
						? "Resume"
						: "Listen";
				toggleBtn.setAttribute("aria-pressed", String(playing));
			};

			audioEl.addEventListener("play", sync);
			audioEl.addEventListener("pause", sync);
			audioEl.addEventListener("ended", () => {
				fillEl.style.width = "0%";
				sync();
			});
			audioEl.addEventListener("timeupdate", () => {
				if (audioEl.duration > 0) {
					fillEl.style.width = `${(audioEl.currentTime / audioEl.duration) * 100}%`;
				}
			});

			toggleBtn.onclick = () => (audioEl.paused ? audioEl.play() : audioEl.pause());
			speedBtn.onclick = () => {
				speedIdx = (speedIdx + 1) % SPEEDS.length;
				audioEl.playbackRate = SPEEDS[speedIdx];
				setSpeedLabel();
			};
		}

		// ========================================================================
		// Mode B: browser speech-synthesis fallback.
		// ========================================================================
		const synth = window.speechSynthesis;
		if (!synth && !src) {
			el.hidden = true;
			return;
		}
		if (!synth) return; // audio probe may still light up Mode A

		let voice: SpeechSynthesisVoice | null = null;
		const pickVoice = () => {
			const vs = synth.getVoices();
			voice =
				vs.find((v) => /^en[-_]?(US|GB|IN)/i.test(v.lang) && v.localService) ||
				vs.find((v) => v.lang.toLowerCase().startsWith("en")) ||
				vs[0] ||
				null;
		};
		pickVoice();
		synth.addEventListener("voiceschanged", pickVoice);

		let chunks: string[] = [];
		let idx = 0;
		let mode: Mode = "idle";
		let token = 0;

		function readableText(): string {
			const prose = document.querySelector(".prose");
			if (!prose) return "";
			const clone = prose.cloneNode(true) as HTMLElement;
			clone.querySelectorAll("pre, table, .listen-skip").forEach((n) => n.remove());
			clone.querySelectorAll("blockquote").forEach((bq) => {
				if (/build-in-public series|you are here|checkpoint/i.test(bq.textContent || ""))
					bq.remove();
			});
			const title =
				document.querySelector<HTMLElement>(".post-header h1")?.innerText.trim() ?? "";
			return (title ? title + ". " : "") + clone.innerText;
		}

		function chunkText(text: string): string[] {
			const clean = text.replace(/\s+/g, " ").trim();
			if (!clean) return [];
			const sentences = clean.match(/[^.!?]+[.!?]+|\S[^.!?]*$/g) || [clean];
			const out: string[] = [];
			let buf = "";
			for (const s of sentences) {
				if (buf && (buf + s).length > 220) {
					out.push(buf.trim());
					buf = "";
				}
				buf += s;
			}
			if (buf.trim()) out.push(buf.trim());
			return out;
		}

		function setUI() {
			const playing = mode === "playing";
			icoEl.textContent = playing ? "⏸" : "▶";
			labelEl.textContent =
				mode === "playing" ? "Pause" : mode === "paused" ? "Resume" : "Listen";
			toggleBtn.setAttribute("aria-pressed", String(mode !== "idle"));
		}

		function speakCurrent() {
			if (mode !== "playing") return;
			if (idx >= chunks.length) {
				stop();
				return;
			}
			const myToken = token;
			const u = new SpeechSynthesisUtterance(chunks[idx]);
			u.rate = SPEEDS[speedIdx];
			if (voice) u.voice = voice;
			u.onend = () => {
				if (myToken !== token || mode !== "playing") return;
				idx += 1;
				speakCurrent();
			};
			synth.speak(u);
		}

		function start() {
			chunks = chunkText(readableText());
			if (chunks.length === 0) return;
			synth.cancel();
			idx = 0;
			token += 1;
			mode = "playing";
			setUI();
			speakCurrent();
		}

		function stop() {
			token += 1;
			synth.cancel();
			mode = "idle";
			setUI();
		}

		toggleBtn.onclick = () => {
			if (mode === "idle") start();
			else if (mode === "playing") {
				synth.pause();
				mode = "paused";
				setUI();
			} else {
				synth.resume();
				mode = "playing";
				setUI();
			}
		};

		speedBtn.onclick = () => {
			speedIdx = (speedIdx + 1) % SPEEDS.length;
			setSpeedLabel();
			if (mode === "playing") {
				token += 1;
				synth.cancel();
				speakCurrent();
			}
		};

		const cancel = () => synth.cancel();
		window.addEventListener("pagehide", cancel);
		window.addEventListener("beforeunload", cancel);
	}

	initListenWidget();
</script>

<style>
	.listen {
		margin: 0 0 2rem;
	}
	.listen-row {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.listen-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text);
		background: var(--bg-subtle);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.32rem 0.8rem;
		cursor: pointer;
		transition:
			border-color 0.15s ease,
			color 0.15s ease;
	}
	.listen-btn:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.listen-btn .ico {
		font-size: 0.7rem;
		line-height: 1;
	}
	.listen-speed {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-muted);
		background: transparent;
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.28rem 0.55rem;
		cursor: pointer;
		min-width: 2.6rem;
	}
	.listen-speed:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.listen-note {
		font-size: 0.72rem;
		color: var(--text-muted);
	}
	.listen-progress {
		height: 3px;
		margin-top: 0.7rem;
		background: var(--border);
		border-radius: 999px;
		overflow: hidden;
	}
	.listen-progress-fill {
		height: 100%;
		width: 0;
		background: var(--accent);
		transition: width 0.2s linear;
	}
	@media (max-width: 640px) {
		.listen-note {
			display: none;
		}
	}
</style>
