---
import HeaderLink from "./HeaderLink.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { SITE_TITLE, NAV_LINKS } from "../consts";

// On the home page the big <h1> already shows the name, so hide the
// header brand there to avoid repeating it.
const isHome = Astro.url.pathname === "/";
---

<header>
	<div class:list={["inner", { "no-brand": isHome }]}>
		{!isHome && <a href="/" class="brand">{SITE_TITLE}</a>}
		<nav>
			{NAV_LINKS.map((l) => <HeaderLink href={l.href}>{l.label}</HeaderLink>)}
			<ThemeToggle />
		</nav>
	</div>
</header>

<style>
	header {
		border-bottom: 1px solid var(--border);
		background: color-mix(in srgb, var(--bg) 85%, transparent);
		backdrop-filter: saturate(140%) blur(8px);
		position: sticky;
		top: 0;
		z-index: 10;
	}
	.inner {
		width: var(--maxw-wide);
		max-width: calc(100% - 2.5rem);
		margin-inline: auto;
		height: 3.5rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}
	.inner.no-brand {
		justify-content: flex-end;
	}
	.brand {
		font-weight: 650;
		letter-spacing: -0.02em;
		color: var(--text);
		font-size: 1rem;
	}
	.brand:hover {
		color: var(--accent);
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		gap: 1.1rem;
	}
	@media (max-width: 480px) {
		nav {
			gap: 0.85rem;
		}
		.inner {
			max-width: calc(100% - 1.5rem);
		}
	}
</style>
