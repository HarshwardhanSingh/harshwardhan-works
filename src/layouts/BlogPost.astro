---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import ListenWidget from "../components/ListenWidget.astro";
import SeriesNav from "../components/SeriesNav.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { findSeries } from "../lib/series";

type Props = CollectionEntry<"blog">["data"] & {
	minutesRead?: string;
	audioSrc?: string;
	slug?: string;
	headings?: { depth: number; slug: string; text: string }[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	minutesRead,
	audioSrc,
	slug,
	headings = [],
} = Astro.props;

const inSeries = slug ? findSeries(slug) : null;

// Audio read-aloud widget temporarily disabled. Flip to true to re-enable
// (regenerate MP3s first: `npm run audio`).
const AUDIO_ENABLED = false;
---

<BaseLayout
	title={title}
	description={description}
	image={heroImage}
	width={inSeries ? "var(--maxw-series)" : undefined}
>
	<div class:list={["post-layout", { "has-series": !!inSeries }]}>
		{
			inSeries && (
				<aside class="series-rail">
					<SeriesNav slug={slug!} />
					<TableOfContents headings={headings} />
				</aside>
			)
		}
		<article>
		<header class="post-header">
			<a href="/blog" class="back">← All writing</a>
			<h1>{title}</h1>
			<div class="meta mono">
				<FormattedDate date={pubDate} />
				{minutesRead && <span>· {minutesRead}</span>}
				{
					updatedDate && (
						<span>· updated <FormattedDate date={updatedDate} /></span>
					)
				}
			</div>
			{
				tags && tags.length > 0 && (
					<ul class="tags">
						{tags.map((t) => (
							<li>#{t}</li>
						))}
					</ul>
				)
			}
		</header>

		{
			heroImage && (
				<img class="hero" src={heroImage} alt="" width={1200} height={630} />
			)
		}

		{AUDIO_ENABLED && <ListenWidget audioSrc={audioSrc} />}

		<div class="prose">
			<slot />
		</div>
		</article>
	</div>
</BaseLayout>

<style>
	/* Two-column layout for posts that belong to a series. Falls back to a
	   plain single column (no grid) for standalone posts. */
	.post-layout.has-series {
		display: grid;
		grid-template-columns: 13rem minmax(0, 1fr);
		gap: 2.75rem;
		align-items: start;
	}
	.series-rail {
		position: sticky;
		top: 5rem;
	}
	@media (max-width: 820px) {
		.post-layout.has-series {
			display: block;
		}
		.series-rail {
			position: static;
			margin-bottom: 2.25rem;
		}
	}
	.post-header {
		margin-bottom: 2rem;
	}
	.back {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-muted);
		display: inline-block;
		margin-bottom: 1.5rem;
	}
	.back:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.post-header h1 {
		font-size: 2.4rem;
		margin-bottom: 0.75rem;
	}
	.meta {
		font-size: 0.82rem;
		color: var(--text-muted);
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.tags {
		list-style: none;
		padding: 0;
		margin: 0.9rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tags li {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--text-muted);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.1rem 0.55rem;
		margin: 0;
	}
	.hero {
		width: 100%;
		aspect-ratio: 1200 / 630;
		object-fit: cover;
		border: 1px solid var(--border);
		margin: 0 0 2rem;
	}
	.prose :global(h2),
	.prose :global(h3) {
		scroll-margin-top: 4.5rem;
	}
	@media (max-width: 640px) {
		.post-header h1 {
			font-size: 1.9rem;
		}
	}
</style>
