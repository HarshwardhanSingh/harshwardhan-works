---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import FormattedDate from "../components/FormattedDate.astro";
import ListenWidget from "../components/ListenWidget.astro";

type Props = CollectionEntry<"blog">["data"] & {
	minutesRead?: string;
	audioSrc?: string;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	minutesRead,
	audioSrc,
} = Astro.props;
---

<BaseLayout title={title} description={description} image={heroImage}>
	<article>
		<header class="post-header">
			<a href="/blog" class="back">← All writing</a>
			<h1>{title}</h1>
			<div class="meta mono">
				<FormattedDate date={pubDate} />
				{minutesRead && <span>· {minutesRead}</span>}
				{
					updatedDate && (
						<span>· updated <FormattedDate date={updatedDate} /></span>
					)
				}
			</div>
			{
				tags && tags.length > 0 && (
					<ul class="tags">
						{tags.map((t) => (
							<li>#{t}</li>
						))}
					</ul>
				)
			}
		</header>

		{
			heroImage && (
				<img class="hero" src={heroImage} alt="" width={1200} height={630} />
			)
		}

		<ListenWidget audioSrc={audioSrc} />

		<div class="prose">
			<slot />
		</div>
	</article>
</BaseLayout>

<style>
	.post-header {
		margin-bottom: 2rem;
	}
	.back {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--text-muted);
		display: inline-block;
		margin-bottom: 1.5rem;
	}
	.back:hover {
		color: var(--accent);
		text-decoration: none;
	}
	.post-header h1 {
		font-size: 2.4rem;
		margin-bottom: 0.75rem;
	}
	.meta {
		font-size: 0.82rem;
		color: var(--text-muted);
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}
	.tags {
		list-style: none;
		padding: 0;
		margin: 0.9rem 0 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.tags li {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		color: var(--text-muted);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.1rem 0.55rem;
		margin: 0;
	}
	.hero {
		width: 100%;
		aspect-ratio: 1200 / 630;
		object-fit: cover;
		border: 1px solid var(--border);
		margin: 0 0 2rem;
	}
	.prose :global(h2),
	.prose :global(h3) {
		scroll-margin-top: 4.5rem;
	}
	@media (max-width: 640px) {
		.post-header h1 {
			font-size: 1.9rem;
		}
	}
</style>
