---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	/** Use the wider column (e.g. for listing pages). */
	wide?: boolean;
	/** Explicit main width (any CSS value); overrides `wide` when set. */
	width?: string;
}

const {
	title = SITE_TITLE,
	description = SITE_DESCRIPTION,
	image,
	wide = false,
	width,
} = Astro.props;

const mainWidth = width ?? (wide ? "var(--maxw-wide)" : undefined);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<Header />
		<main style={mainWidth ? `width: ${mainWidth}` : undefined}>
			<slot />
		</main>
		<Footer />
	</body>
</html>
